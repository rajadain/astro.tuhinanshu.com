---
export interface Props {
  tags: string[];
  activeTag?: string;
  class?: string;
}

const { tags, activeTag, class: className } = Astro.props;
---

<ul class:list={["radar-tags", className]}>
  {
    tags.map(tag => (
      <li>
        <a
          href={`/radar/tags/${tag.toLowerCase()}`}
          class:list={[
            "tag-pill",
            { "tag-pill-active": activeTag && tag.toLowerCase() === activeTag },
          ]}
        >
          #{tag.toLowerCase()}
        </a>
      </li>
    ))
  }
</ul>

<style>
  @reference "../styles/base.css";

  .radar-tags {
    @apply flex list-none flex-wrap gap-2 p-0;
  }
  .tag-pill {
    @apply bg-skin-accent/10 text-skin-accent hover:bg-skin-accent/20 inline-block rounded-full
      px-2.5 py-0.5 text-xs font-medium no-underline transition-colors;
  }
  .tag-pill-active {
    @apply bg-skin-accent text-skin-inverted hover:bg-skin-accent/90;
  }
</style>
