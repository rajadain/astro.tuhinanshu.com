---
import { marked } from "marked";
import { Icon } from "astro-icon/components";
import type { RadarEntry } from "@content/_schemas";
import RadarTagList from "@components/RadarTagList.astro";

export interface Props {
  data: RadarEntry;
  activeTag?: string;
}

const { data, activeTag } = Astro.props;
const { id, url, timestamp, context, tags, og } = data;

const contextHtml = marked.parse(context);
const dateStr = new Date(timestamp).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const urlHostname = new URL(url).hostname;
---

<li class="radar-card" id={`radar-item-${id}`}>
  {/* OG Link Card Preview */}
  {
    (og.title || og.description || og.image) && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="og-preview"
      >
        {og.image && (
          <img
            src={og.image}
            alt={og.title || ""}
            class="og-image"
            loading="lazy"
          />
        )}
        <div class="og-text">
          {og.title && <span class="og-title">{og.title}</span>}
          {og.description && (
            <span class="og-description">{og.description}</span>
          )}
          <span class="og-url">{urlHostname}</span>
        </div>
      </a>
    )
  }

  {/* Context */}
  <div class="prose radar-context" set:html={contextHtml} />

  {/* Meta row */}
  <div class="radar-meta">
    <a href={`/radar/item/${id}`} class="detail-link">
      <div class="flex items-center space-x-1">
        <Icon name="tabler:calendar-star" class="scale-75 pb-1" />
        <time datetime={new Date(timestamp).toISOString()} class="italic"
          >{dateStr}</time
        >
      </div>
    </a>
  </div>

  {/* Tags */}
  <RadarTagList tags={tags} activeTag={activeTag} />
</li>

<style>
  @reference "../styles/base.css";

  .radar-card {
    @apply border-skin-line border-b px-5 pt-0 pb-6;

    &:last-of-type {
      @apply border-b-0;
    }
  }

  /* OG Link Card */
  .og-preview {
    @apply mb-4 flex overflow-hidden rounded-md
      no-underline transition-opacity hover:opacity-90;
  }
  .og-image {
    @apply h-auto w-32 shrink-0 object-cover sm:w-40;
  }
  .og-text {
    @apply flex flex-col justify-center gap-1 p-3;
  }
  .og-title {
    @apply text-skin-base font-headings leading-snug font-semibold;
  }
  .og-description {
    @apply text-skin-base/70 line-clamp-2 text-sm;
  }
  .og-url {
    @apply text-skin-accent text-sm;
  }

  /* Context */
  .radar-context {
    @apply mb-3 max-w-none px-3;
  }

  /* Meta row */
  .radar-meta {
    @apply text-skin-base/60 mb-2 flex items-center gap-2 px-3 text-sm;
  }
  .radar-meta time {
    @apply font-mono;
  }
  .meta-sep {
    @apply opacity-50;
  }
  .detail-link {
    @apply text-skin-accent decoration-dashed underline-offset-4 hover:underline;
  }
</style>
